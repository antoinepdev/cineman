---
import Layout from "../layouts/Layout.astro";
---
<Layout>
  <main class="grid min-h-full place-items-center px-6 py-24 sm:py-32 lg:px-8">
    <div class="text-center">
      <p class="text-base font-semibold text-primary">404</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-tight text-balance text-white sm:text-7xl">Página no encontrada</h1>
      <p class="mt-6 text-lg font-medium text-pretty text-gray-400 sm:text-xl/8">Lo sentimos, no hemos encontrado la página que buscas.</p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a href="/cineman" class="btn-primary font-semibold">← Ir a la página principal</a>
      </div>
    </div>
  </main>
</Layout>
