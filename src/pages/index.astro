---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import Catalog from "../components/Catalog.astro";
import movies from "../movies/movies.json";
---

<Layout>
  <Hero />
  <Features />
  <Catalog movies={movies} catalog='Standard v0'/>
  <div class="border-t-2 mx-auto border-t-neutral w-full md:w-3/4 my-container"></div>
  <Footer />
</Layout>
