---
const featuresData = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-primary size-8 mt-4"> <path stroke="none" d="M0 0h24v24H0z" fill="none" /> <path d="M9 6.371c0 4.418 -2.239 6.629 -5 6.629" /> <path d="M4 6.371h7" /> <path d="M5 9c0 2.144 2.252 3.908 6 4" /> <path d="M12 20l4 -9l4 9" /> <path d="M19.1 18h-6.2" /> <path d="M6.694 3l.793 .582" /> </svg>`,
    title: "In spanish please",
    description: "El 95% de las pelis están en Español Latino/Castellano y 5% subtituladas al español.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-primary size-8 mt-4"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/></svg>`,
    title: "Tienes el control",
    description: "Todo el catálogo será enviado a un canal o grupo de tu preferencia, por tanto podrás compartir los archivos con quien gustes.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-primary size-8 mt-4"><path d="M8.3 10a.7.7 0 0 1-.626-1.079L11.4 3a.7.7 0 0 1 1.198-.043L16.3 8.9a.7.7 0 0 1-.572 1.1Z"/><rect x="3" y="14" width="7" height="7" rx="1"/><circle cx="17.5" cy="17.5" r="3.5"/></svg>`,
    title: "Gran variedad",
    description: "Desde clásicos hasta los estrenos más recientes de 2026.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" class="text-primary size-8 mt-4"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M7 15h-3a1 1 0 0 1 -1 -1v-8a1 1 0 0 1 1 -1h12a1 1 0 0 1 1 1v3" /><path d="M7 10a1 1 0 0 1 1 -1h12a1 1 0 0 1 1 1v8a1 1 0 0 1 -1 1h-12a1 1 0 0 1 -1 -1l0 -8" /><path d="M12 14a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /></svg>`,
    title: "Múltiples métodos de pago",
    description: "Paga mediante Paypal, estrellas de Telegram o culaquier criptomoneda.",
  }
]
---

<section class="mt-section">
  <h2 class="section-title">Por Qué Elegirnos?</h2>
  <div class="flex flex-wrap items-center justify-center gap-card mt-card">
    {
      featuresData.map((feature, index) => {
        const cardContent = (
        <div class="p-card rounded-xl space-y-3 border border-neutral bg-surface max-w-80 w-full h-60 hover:-translate-y-0.5 transition duration-300">
            <div set:html={feature.icon} />
            <h3 class="text-title under">{feature.title}</h3>
          <p class="text-subtitle pb-card">{feature.description}</p>
          </div>
        );
        return cardContent
      })
    }
  </div>
</section>

